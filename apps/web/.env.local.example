# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of extra admin emails (owner dipanbaral05@gmail.com is always included)
ADMIN_EMAILS=

# ── Optional: Site URL (needed for email magic links / OAuth redirects) ───────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── USDA FoodData Central (free) ─────────────────────────────────────────────
# Sign up at https://fdc.nal.usda.gov/api-key-signup — falls back to DEMO_KEY if omitted
VITE_USDA_API_KEY=
